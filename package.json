{
  "name": "zm-index",
  "version": "1.0.0",
  "description": "Fast local code symbol index for AI coding assistants. CLI tool for TypeScript/JavaScript projects.",
  "scripts": {
    "test": "node --import tsx/esm --test tests/unit/extractor.test.ts tests/unit/db.test.ts tests/integration/cli.test.ts",
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "code-index",
    "symbol-search",
    "cli",
    "typescript",
    "ai",
    "developer-tools",
    "sqlite",
    "code-navigation"
  ],
  "author": "Zhanna Myshkovskaya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZhannaM85/zm-index.git"
  },
  "homepage": "https://github.com/ZhannaM85/zm-index#readme",
  "bugs": {
    "url": "https://github.com/ZhannaM85/zm-index/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "bin": {
    "zm-index": "dist/cli.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "commander": "^15.0.0",
    "ignore": "^7.0.5",
    "tree-sitter": "^0.21.1",
    "tree-sitter-c-sharp": "^0.21.1",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-rust": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist/",
    "README.md"
  ]
}
